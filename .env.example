PORT=8080

# DB_DRIVER selects the storage backend: "sqlite" or "mongo".
DB_DRIVER=sqlite

# Used when DB_DRIVER=sqlite
DB_PATH=data/bookmarks.db

# Used when DB_DRIVER=mongo. The connection string is built from these
# parts: mongodb+srv://<username>:<password>@<host>/?appName=<app_name>
MONGODB_USERNAME=<db_username>
MONGODB_PASSWORD=
MONGODB_HOST=<sub_domain>.mongodb.net
MONGODB_APP_NAME=Cluster0
MONGODB_DATABASE=bookmarks

# Single-user login gating the whole app. Both are case-sensitive.
# AUTH_USERNAME: 3+ chars is enough, it isn't secret.
# AUTH_PASSWORD: 16+ random chars recommended (e.g. openssl rand -base64 24),
# since there's no rate-limiting/lockout on /login yet.
AUTH_USERNAME=
AUTH_PASSWORD=
# Signs the session cookie. Required for sessions to survive a restart.
# Case-sensitive; changing it (even casing) invalidates all existing sessions.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Google reCAPTCHA v2 ("I'm not a robot" checkbox) on the login page.
# Get keys at https://www.google.com/recaptcha/admin. Leave both blank to
# disable the checkbox entirely (no widget shown, no verification done).
# RECAPTCHA_ENABLED toggles it off without touching the keys below — handy
# for local/scripted logins. Defaults to true if unset.
RECAPTCHA_ENABLED=true
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
